  "csv_paths": {
    "description": "TDA00-03 ParaTranz CSV 路径",
    "type": "list",
    "hint": "每个 CSV 应为三列：key, JP, CN。key 形如 TDA02|xxx.egpack|game_t00000。",
    "default": [
